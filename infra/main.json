{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "4796227379890276765"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "containerAppEnvName": {
      "type": "string",
      "defaultValue": "cae-articletts"
    },
    "containerAppName": {
      "type": "string",
      "defaultValue": "ca-articletts"
    },
    "image": {
      "type": "string",
      "defaultValue": "mcr.microsoft.com/k8se/quickstart:latest",
      "metadata": {
        "description": "Container image to deploy. Defaults to a public bootstrap placeholder so the Container App can be created before the real private GHCR image exists. The deploy-app workflow swaps in the real image."
      }
    },
    "speechAccountName": {
      "type": "string",
      "defaultValue": "[format('sp{0}', take(uniqueString(subscription().id, resourceGroup().id), 20))]"
    },
    "speechCustomSubdomain": {
      "type": "string",
      "defaultValue": "[format('sp{0}', take(uniqueString(resourceGroup().id, 'speech-subdomain'), 20))]"
    },
    "maxReplicas": {
      "type": "int",
      "defaultValue": 1
    },
    "minReplicas": {
      "type": "int",
      "defaultValue": 0
    }
  },
  "resources": [
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppEnvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "zoneRedundant": false
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2024-10-01",
      "name": "[parameters('speechAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "F0"
      },
      "kind": "SpeechServices",
      "properties": {
        "customSubDomainName": "[parameters('speechCustomSubdomain')]",
        "publicNetworkAccess": "Enabled",
        "disableLocalAuth": true
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto"
          },
          "activeRevisionsMode": "Single"
        },
        "template": {
          "containers": [
            {
              "name": "web",
              "image": "[parameters('image')]",
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              },
              "env": [
                {
                  "name": "PORT",
                  "value": "8080"
                },
                {
                  "name": "SPEECH_ENDPOINT",
                  "value": "[format('https://{0}.cognitiveservices.azure.com', parameters('speechCustomSubdomain'))]"
                },
                {
                  "name": "SPEECH_RESOURCE_ID",
                  "value": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('speechAccountName'))]"
                },
                {
                  "name": "MAX_ARTICLE_CHARS",
                  "value": "12000"
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": "[parameters('maxReplicas')]",
            "rules": [
              {
                "name": "http-scaling",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppEnvName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', parameters('speechAccountName'))]"
      ]
    }
  ],
  "outputs": {
    "containerAppName": {
      "type": "string",
      "value": "[parameters('containerAppName')]"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01').configuration.ingress.fqdn]"
    },
    "containerAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName')), '2024-03-01', 'full').identity.principalId]"
    },
    "speechResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('speechAccountName'))]"
    },
    "speechEndpoint": {
      "type": "string",
      "value": "[format('https://{0}.cognitiveservices.azure.com', parameters('speechCustomSubdomain'))]"
    }
  }
}